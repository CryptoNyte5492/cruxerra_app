# Local development can continue using SQLite without DATABASE_URL.
# For production, copy the PostgreSQL connection string from your host here or
# configure it in the host's environment-variable dashboard. Do not commit .env.
DATABASE_URL=postgresql://username:password@host:5432/database_name
DJANGO_SECRET_KEY=replace-with-a-long-random-secret
EMAIL_HOST_USER=your-email@example.com
EMAIL_HOST_PASSWORD=your-email-app-password
